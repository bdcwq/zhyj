generator client {
  provider = "prisma-client-js"
}

datasource db {
  // For SQLite (development): provider = "sqlite", url = "file:./dev.db"
  // For PostgreSQL (production): provider = "postgresql", url = env("DATABASE_URL")
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ── Store ──────────────────────────────────────────────────────────────
model Store {
  id        String   @id @default(cuid())
  name      String
  address       String?
  phone         String?
  businessHours String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  rooms     Room[]
  machines  Machine[]
  staffStores StaffStore[]

  residentStores    ResidentStore[]
  monitoringRecords MonitoringRecord[]
  appointments      Appointment[]
  verifications     Verification[]
  robotSessions     RobotSession[]
  notifications     Notification[]
  campaigns         Campaign[]
  campaignParticipations CampaignParticipation[]
  shiftTemplates  ShiftTemplate[]
  schedules       Schedule[]
  attendances     Attendance[]
  leaves          Leave[]
}

// ── Room ───────────────────────────────────────────────────────────────
model Room {
  id        String   @id @default(cuid())
  name      String
  storeId   String
  capacity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  store        Store         @relation(fields: [storeId], references: [id])
  appointments Appointment[]

  machines Machine[]
}

// ── Machine ────────────────────────────────────────────────────────────
model Machine {
  id        String   @id @default(cuid())
  name      String
  storeId   String
  roomId    String?
  status    String   @default("available")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  store        Store         @relation(fields: [storeId], references: [id])
  room         Room?         @relation(fields: [roomId], references: [id])
  appointments Appointment[]
}

// ── Staff ──────────────────────────────────────────────────────────────
model Staff {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  phone     String   @unique
  name      String
  role      String   @default("staff")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  staffStores  StaffStore[]
  appointments Appointment[]
  schedules    Schedule[]
  attendances  Attendance[]
  leaves       Leave[]
  approvedLeaves Leave[] @relation("LeaveApprover")
}

// ── StaffStore (junction) ─────────────────────────────────────────────
model StaffStore {
  id        String   @id @default(cuid())
  staffId   String
  storeId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([staffId, storeId])
}

// ── ResidentStore (junction) ──────────────────────────────────────────
model ResidentStore {
  id         String   @id @default(cuid())
  residentId String
  storeId    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  resident Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([residentId, storeId])
}

// ── Resident ───────────────────────────────────────────────────────────
model Resident {
  id                String   @id @default(cuid())
  name              String
  phone             String   @unique
  wechatOpenid      String?  @unique
  registrationSource String  @default("walk-in")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  residentStores    ResidentStore[]
  monitoringRecords MonitoringRecord[]
  appointments      Appointment[]
}

// ── MonitoringRecord ───────────────────────────────────────────────────
model MonitoringRecord {
  id               String   @id @default(cuid())
  residentId       String
  score            Int
  monitoringDate   DateTime
  constitutionType String?
  storeId          String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  resident Resident @relation(fields: [residentId], references: [id])
  store     Store    @relation(fields: [storeId], references: [id])
}

// ── Appointment ────────────────────────────────────────────────────────
model Appointment {
  id          String    @id @default(cuid())
  residentId  String
  staffId     String?
  roomId      String?
  machineId   String?
  scheduledAt DateTime
  status      String    @default("booked")
  noShowCount Int       @default(0)
  storeId     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  resident       Resident       @relation(fields: [residentId], references: [id])
  staff          Staff?         @relation(fields: [staffId], references: [id])
  room           Room?          @relation(fields: [roomId], references: [id])
  machine        Machine?       @relation(fields: [machineId], references: [id])
  store          Store          @relation(fields: [storeId], references: [id])
  verification   Verification?
  robotSessions  RobotSession[]
}

// ── Verification ───────────────────────────────────────────────────────
model Verification {
  id         String   @id @default(cuid())
  appointmentId String @unique
  verifiedBy String
  verifiedAt DateTime
  storeId    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  store       Store       @relation(fields: [storeId], references: [id])
}

// ── RobotSession ───────────────────────────────────────────────────────
model RobotSession {
  id           String    @id @default(cuid())
  appointmentId String
  routine      String?
  status       String    @default("active")
  startedAt    DateTime
  endedAt      DateTime?
  storeId      String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  store       Store       @relation(fields: [storeId], references: [id])
}

// ── Notification ───────────────────────────────────────────────────────
model Notification {
  id            String    @id @default(cuid())
  type          String    // appointment_reminder, campaign_reward, no_show_warning, custom
  recipientType String    // staff, resident
  recipientId   String
  title         String
  content       String
  status        String    @default("pending") // pending, sent, failed
  channel       String    @default("console") // console, wechat
  sentAt        DateTime?
  error         String?
  storeId       String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  store Store @relation(fields: [storeId], references: [id])
}

// ── Campaign ───────────────────────────────────────────────────────────
model Campaign {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("referral") // referral, promotion, etc.
  rules     String   // JSON string: { bonusAppointments: number, rewardCondition: string }
  startDate DateTime
  endDate   DateTime
  priority  Int      @default(0) // higher = higher priority
  status    String   @default("active") // active, paused, expired
  storeId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  store Store @relation(fields: [storeId], references: [id])
  participations CampaignParticipation[]
}

// ── CampaignParticipation ──────────────────────────────────────────────
model CampaignParticipation {
  id           String    @id @default(cuid())
  campaignId   String
  referrerId   String    // the resident who referred
  refereeId    String    // the resident who was referred
  status       String    @default("pending") // pending, completed, expired
  completedAt  DateTime?
  storeId      String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id])
  store    Store    @relation(fields: [storeId], references: [id])

  @@unique([campaignId, refereeId])
}

// ── ShiftTemplate ─────────────────────────────────────────────────────
model ShiftTemplate {
  id            String   @id @default(cuid())
  name          String
  storeId       String
  shifts        String   // JSON: [{type, startTime, endTime, requiredStaff}]
  effectiveDays String   // JSON: [1,2,3,4,5] (ISO weekday numbers)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  store     Store     @relation(fields: [storeId], references: [id])
  schedules Schedule[]
}

// ── Schedule ───────────────────────────────────────────────────────────
model Schedule {
  id         String   @id @default(cuid())
  date       DateTime
  staffId    String
  storeId    String
  shiftType  String
  startTime  String   // "HH:mm"
  endTime    String   // "HH:mm"
  status     String   @default("scheduled") // scheduled, cancelled, completed
  templateId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  store    Store          @relation(fields: [storeId], references: [id])
  staff    Staff          @relation(fields: [staffId], references: [id])
  template ShiftTemplate? @relation(fields: [templateId], references: [id])
  attendances Attendance[]

  @@unique([staffId, date, shiftType])
  @@index([storeId, date])
  @@index([staffId, date])
}

// ── Attendance ─────────────────────────────────────────────────────────
model Attendance {
  id            String    @id @default(cuid())
  staffId       String
  storeId       String
  scheduleId    String?
  date          DateTime
  clockIn       DateTime?
  clockOut      DateTime?
  status        String    @default("pending") // pending, normal, late, early_leave, late_and_early, absent
  scheduledStart String?
  scheduledEnd   String?
  workedMinutes Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  store    Store     @relation(fields: [storeId], references: [id])
  staff    Staff     @relation(fields: [staffId], references: [id])
  schedule Schedule? @relation(fields: [scheduleId], references: [id])

  @@unique([staffId, date, scheduleId])
  @@index([storeId, date])
  @@index([staffId, date])
  @@index([status])
}

// ── Leave ──────────────────────────────────────────────────────────────
model Leave {
  id          String    @id @default(cuid())
  staffId     String
  storeId     String
  type        String    // sick, personal, annual, other
  startDate   DateTime
  endDate     DateTime
  status      String    @default("pending") // pending, approved, rejected
  reason      String?
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  store     Store     @relation(fields: [storeId], references: [id])
  staff     Staff     @relation(fields: [staffId], references: [id])
  approver  Staff?    @relation("LeaveApprover", fields: [approvedBy], references: [id])

  @@index([storeId, status])
  @@index([staffId, status])
  @@index([startDate, endDate])
}
